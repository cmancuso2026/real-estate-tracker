# ---------------------------------------------------------------------------
# Real Estate Tracker — environment configuration
# Copy this file to ".env" and fill in your keys. Never commit ".env".
# ---------------------------------------------------------------------------

# SQLite database file location (relative to project root).
DATABASE_PATH=./data/tracker.db

# --- Rentcast (https://www.rentcast.io/api) --------------------------------
# Used to fetch rental comps by zip code.
RENTCAST_API_KEY=

# --- Zillow via RapidAPI (https://rapidapi.com/) ---------------------------
# Subscribe to a Zillow data provider on RapidAPI and paste the key + host.
RAPIDAPI_KEY=
# The host header for the specific Zillow API you subscribed to.
# Example: zillow-com1.p.rapidapi.com
RAPIDAPI_ZILLOW_HOST=zillow-com1.p.rapidapi.com

# --- Realtor.com (later phase) ---------------------------------------------
REALTOR_API_KEY=

# --- Target markets --------------------------------------------------------
# Comma-separated list of zip codes to track.
TARGET_ZIP_CODES=78704,78745

# --- Phase 2: scoring engine -----------------------------------------------
# Premium added to the Freddie Mac PMMS base rate for investment loans (% APR).
INVESTMENT_RATE_PREMIUM=0.75
# Source for the 30-yr fixed rate (Freddie Mac PMMS historical CSV).
FREDDIE_MAC_PMMS_CSV_URL=https://www.freddiemac.com/pmms/docs/PMMS_history.csv
# Optional manual override of the base 30-yr rate (% APR), e.g. when offline.
MANUAL_PMMS_RATE=
# Crime component (optional — skipped and weights renormalized if unset).
SPOTCRIME_API_KEY=
# Miami-Dade county median crime index used as the crime baseline.
MIAMI_DADE_CRIME_MEDIAN=
# Census ACS renter-occupancy (optional key; ACS allows limited keyless use).
CENSUS_API_KEY=

# --- Phase 3+ (placeholders) -----------------------------------------------
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
