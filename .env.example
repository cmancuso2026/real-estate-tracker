# ---------------------------------------------------------------------------
# Real Estate Tracker — environment configuration
# Copy this file to ".env" and fill in your keys. Never commit ".env".
# ---------------------------------------------------------------------------

# SQLite database file location (relative to project root).
DATABASE_PATH=./data/tracker.db

# --- Rentcast (https://www.rentcast.io/api) --------------------------------
# Used to fetch rental comps by zip code.
RENTCAST_API_KEY=

# --- Zillow via RapidAPI (https://rapidapi.com/) ---------------------------
# Subscribe to a Zillow data provider on RapidAPI and paste the key + host.
RAPIDAPI_KEY=
# The host header for the specific Zillow API you subscribed to. The fetch
# code targets this provider's /search?location=<zip> endpoint.
# Example: us-property-market1.p.rapidapi.com
RAPIDAPI_ZILLOW_HOST=us-property-market1.p.rapidapi.com

# --- Realtor.com (later phase) ---------------------------------------------
REALTOR_API_KEY=

# --- Target markets --------------------------------------------------------
# Comma-separated list of zip codes to track.
TARGET_ZIP_CODES=78704,78745
# How often (days) to refresh Rentcast rental comps per zip. Zillow listings
# refresh on every fetch:all run; Rentcast is throttled to conserve API quota.
# Default 7 (weekly). Use `npm run fetch:rentals <zip>` to force a refresh.
RENTAL_REFRESH_DAYS=7

# --- Phase 2: scoring engine -----------------------------------------------
# Premium added to the Freddie Mac PMMS base rate for investment loans (% APR).
INVESTMENT_RATE_PREMIUM=0.75
# Source for the 30-yr fixed rate (Freddie Mac PMMS historical CSV).
FREDDIE_MAC_PMMS_CSV_URL=https://www.freddiemac.com/pmms/docs/PMMS_history.csv
# Optional manual override of the base 30-yr rate (% APR), e.g. when offline.
MANUAL_PMMS_RATE=
# Crime component — FBI Crime Data Explorer (https://api.usa.gov/crime/fbi/cde).
# No registration required: the shared "DEMO_KEY" works but is heavily rate
# limited. Grab a free key at https://api.data.gov/signup/ for batch grading.
# Maps each zip to its Miami-Dade city (src/scoring/zip-cities.ts), grades that
# city's police-agency crime rate per 100k against the median of all tracked
# cities (computed automatically). Verify coverage with `npm run crime:check`.
FBI_API_KEY=DEMO_KEY
# Census ACS renter-occupancy (optional key; ACS allows limited keyless use).
CENSUS_API_KEY=

# --- Phase 4: notifications ------------------------------------------------
# Slack incoming webhook for grade-A alerts (https://api.slack.com/messaging/webhooks).
SLACK_WEBHOOK_URL=
# SendGrid daily email digest (https://app.sendgrid.com/settings/api_keys).
SENDGRID_API_KEY=
# Verified sender address and recipient(s) (recipients may be comma-separated).
SENDGRID_FROM_EMAIL=
SENDGRID_TO_EMAIL=

# --- Phase 3+ (placeholders) -----------------------------------------------
ANTHROPIC_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
