{
  "name": "real-estate-tracker",
  "version": "0.1.0",
  "description": "Real estate investment tracker — fetches for-sale listings and rental comps, grades properties A-F, and sends alerts.",
  "type": "module",
  "scripts": {
    "build": "npm run dashboard:install && npm run dashboard:build",
    "start": "npm run db:migrate && npm --prefix src/dashboard run start",
    "worker": "npm run db:migrate && npm run scheduler",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx src/db/init.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "fetch:rentals": "tsx src/scripts/fetch-rentals.ts",
    "fetch:listings": "tsx src/scripts/fetch-listings.ts",
    "fetch:all": "tsx src/scripts/fetch-all.ts",
    "refresh:rate": "tsx src/scripts/refresh-rate.ts",
    "grade": "tsx src/scripts/grade-listings.ts",
    "crime:check": "tsx src/scripts/check-crime.ts",
    "seed:demo": "tsx src/scripts/seed-demo.ts",
    "dashboard:install": "npm --prefix src/dashboard install",
    "dashboard:dev": "npm --prefix src/dashboard run dev",
    "dashboard:build": "npm --prefix src/dashboard run build",
    "notify:slack": "tsx src/scripts/notify-slack.ts",
    "notify:email": "tsx src/scripts/notify-email.ts",
    "notify:email:weekly": "tsx src/scripts/notify-email-weekly.ts",
    "scheduler": "tsx src/scheduler/index.ts",
    "test:slack": "tsx src/scripts/test-slack.ts",
    "test:email": "tsx src/scripts/test-email.ts",
    "v2:recap": "tsx src/scripts/v2-recap.ts",
    "v2:alerts": "tsx src/scripts/v2-alerts.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.3"
  }
}
